# =============================================
# Backend Environment Variables — TEMPLATE
# Sao chép file này thành .env và điền giá trị thật
# KHÔNG commit .env lên Git
# =============================================

PORT=5000

# MongoDB: trong Docker Compose dùng "mongo" (service name), local dùng 127.0.0.1
MONGO_URL=mongodb://mongo:27017/pickleball_booking

# Redis: trong Docker Compose dùng "redis" (service name), local dùng 127.0.0.1
REDIS_URL=redis://redis:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Nodemailer (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS: URL frontend trỏ tới (để whitelist trong CORS config)
# Trong Docker: http://localhost (Nginx serve frontend ở cổng 80)
FRONTEND_URL=http://localhost
